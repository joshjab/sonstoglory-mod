---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Videos" description="Teaching videos by Paul Jablonowski on the Kingdom of Jesus Christ.">
  <div class="max-w-3xl mx-auto px-4 py-16 text-center">
    <h1 class="font-heading text-4xl text-primary mb-4">Videos</h1>
    <p class="text-gray-500 text-lg mb-6">YouTube integration coming soon.</p>
    <a
      href="https://youtube.com/@coolpixstargazer"
      target="_blank"
      rel="noopener"
      class="inline-block px-6 py-3 rounded font-semibold no-underline text-white hover:opacity-90"
      style="background:#1A2350;"
    >
      Watch on YouTube →
    </a>
  </div>
</BaseLayout>
