---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import allVideos from '../data/videos.json';

const latestVideos = allVideos.slice(0, 2);

const newsletters = (await getCollection('newsletters'))
  .filter(n => n.data.type === 'newsletter' && n.data.number)
  .sort((a, b) => (b.data.number ?? 0) - (a.data.number ?? 0))
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/(\/?)$/, '/');

const carouselImages = [
  'images/newsletters/pictures/King_Jesus_in_the_Clouds_as_Bridegroom.JPG',
  'images/newsletters/pictures/3crosses.jpg',
  'images/newsletters/pictures/dove_with_an_olive_branch.jpg',
  'images/newsletters/pictures/GloryRide1.jpg',
];
const delays = ['0s', '-18s', '-12s', '-6s'];

function extractCardImage(body) {
  const m = body.match(/<img[^>]+src="([^"]+)"/);
  if (!m) return null;
  const src = m[1];
  return src.startsWith('/') ? `${base}${src.slice(1)}` : src;
}
---

<BaseLayout title="Home" description="Theological writings, newsletters, and resources by Paul Jablonowski — freely given for the Everlasting Kingdom of Jesus.">

  <!-- Hero with CSS-only carousel -->
  <section class="relative text-white overflow-hidden" style="min-height: 440px; background-color: #0D1122;">

    <!-- Carousel slides -->
    {carouselImages.map((img, i) => (
      <div
        class="carousel-slide absolute inset-0 bg-no-repeat bg-center"
        style={`background-image: url('${base}${img}'); background-size: 50%; animation-delay: ${delays[i]};`}
      />
    ))}

    <!-- Full-section dim overlay -->
    <div class="absolute inset-0" style="background: rgba(10,14,30,0.60);" />

    <!-- Text content with its own frosted backdrop -->
    <div class="relative z-10 flex items-center justify-center py-20 px-4" style="min-height: 440px;">
      <div class="max-w-2xl w-full text-center rounded-2xl px-8 py-10" style="background: rgba(10,14,30,0.55); backdrop-filter: blur(2px);">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #C8912A;">
          Freely Given for the Kingdom of Jesus Christ
        </p>
        <h1 class="font-heading text-5xl md:text-6xl font-bold text-white mb-5 leading-tight">
          Sons To Glory
        </h1>
        <p class="text-lg mb-8 leading-relaxed" style="color: #c7d4e8;">
          Theological writings on sonship, the Biblical feasts, prophecy,
          and the Everlasting Kingdom — by Paul Jablonowski.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`${base}book/`} class="px-7 py-3 rounded font-semibold no-underline hover:opacity-90 transition-opacity" style="background:#C8912A; color:#fff;">
            Read the Book
          </a>
          <a href={`${base}newsletters/`} class="border-2 border-white text-white px-7 py-3 rounded font-semibold no-underline hover:bg-white hover:text-primary transition-colors">
            Browse Newsletters
          </a>
        </div>
      </div>
    </div>

  </section>

  <!-- Latest Newsletters -->
  <section class="max-w-5xl mx-auto px-4 py-14">
    <h2 class="font-heading text-3xl text-primary mb-8">Latest Newsletters</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {newsletters.map(n => {
        const cardImage = extractCardImage(n.body);
        const displayTitle = n.data.title.replace(/^Newsletter #\d+\s*[-—]?\s*/i, '');
        const formattedDate = n.data.date
          ? new Date(n.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })
          : null;
        return (
          <a
            href={`${base}newsletters/${n.slug}/`}
            class="flex flex-col bg-white rounded-lg shadow-sm border border-gray-100 no-underline hover:shadow-md transition-shadow overflow-hidden"
          >
            {cardImage ? (
              <div class="h-40 overflow-hidden bg-gray-100">
                <img src={cardImage} alt="" class="w-full h-full object-cover" loading="lazy" />
              </div>
            ) : (
              <div class="h-40 flex items-center justify-center" style="background:#1A2350;">
                <span class="font-heading text-4xl font-bold text-white opacity-30">#{n.data.number}</span>
              </div>
            )}
            <div class="p-5 flex flex-col flex-1">
              <span class="text-xs font-semibold uppercase tracking-wide mb-1" style="color:#C8912A;">Issue #{n.data.number}</span>
              <h3 class="font-heading text-base text-primary leading-snug font-semibold mb-2 flex-1">{displayTitle}</h3>
              {formattedDate && <p class="text-xs text-gray-400 mt-auto">{formattedDate}</p>}
            </div>
          </a>
        );
      })}
    </div>
    <div class="mt-8 text-center">
      <a href={`${base}newsletters/`} class="text-primary font-semibold hover:text-accent">
        View all 41 newsletters →
      </a>
    </div>
  </section>

  <!-- Latest Videos -->
  <section class="max-w-5xl mx-auto px-4 py-14">
    <h2 class="font-heading text-3xl text-primary mb-8">Latest Videos</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" id="home-video-grid">
      {latestVideos.map(v => (
        <div class="video-card rounded-lg overflow-hidden shadow-sm border border-gray-100 bg-white" data-id={v.id}>
          <button class="video-thumb block w-full relative cursor-pointer border-0 p-0 bg-transparent" aria-label={`Play ${v.title}`}>
            <img src={v.thumbnail} alt={v.title} class="w-full h-44 object-cover" loading="lazy" />
            <span class="absolute inset-0 flex items-center justify-center">
              <span class="w-14 h-14 rounded-full flex items-center justify-center" style="background:rgba(220,38,38,0.88);">
                <svg viewBox="0 0 24 24" class="w-7 h-7 text-white fill-current" style="margin-left:3px;"><polygon points="5,3 19,12 5,21"/></svg>
              </span>
            </span>
          </button>
          <div class="p-4">
            <p class="font-heading text-sm text-primary font-semibold leading-snug">{v.title}</p>
            <p class="text-xs text-gray-400 mt-1">
              {new Date(v.published).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
            </p>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href={`${base}videos/`} class="text-primary font-semibold hover:text-accent">View all videos →</a>
    </div>
  </section>

  <!-- Free Book CTA — warm cream, dark text -->
  <section class="py-14 px-4" style="background: #F0EBE0;">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-10">
      <div class="flex gap-3 shrink-0">
        <img src={`${base}images/images/sonstoglorycover.jpg`} alt="Sons To Glory book cover" class="h-52 w-auto shadow-lg rounded" />
        <img src={`${base}images/images/sonstoglorybackcover.jpg`} alt="Sons To Glory back cover" class="h-52 w-auto shadow-lg rounded hidden sm:block" />
      </div>
      <div>
        <h2 class="font-heading text-3xl text-primary mb-3">Sons To Glory — Free Book</h2>
        <p class="mb-6 text-lg leading-relaxed" style="color:#3a3a4a;">
          A multi-chapter exploration of spiritual sonship, the Biblical feasts, and the
          Everlasting Kingdom. Read online or download the PDF — freely given.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`${base}book/`} class="px-6 py-3 rounded font-semibold no-underline hover:opacity-90 text-center text-white" style="background:#1A2350;">
            Read Online
          </a>
          <a href={`${base}pdfs/SonsToGloryBook.pdf`} target="_blank" class="px-6 py-3 rounded font-semibold no-underline text-center transition-colors hover:text-white" style="border:2px solid #C8912A; color:#C8912A; --tw-hover-bg:#C8912A;">
            Download PDF
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Subscribe CTA — deep navy, readable -->
  <section class="py-14 px-4 text-center" style="background:#1A2350;">
    <h2 class="font-heading text-2xl text-white mb-3">Stay Connected</h2>
    <p class="mb-6" style="color:#9eb4cc;">
      Subscribe to receive new writings and updates from Paul Jablonowski.
    </p>
    <a href={`${base}subscribe/`} class="inline-block px-6 py-3 rounded font-semibold no-underline hover:opacity-90" style="background:#C8912A; color:#fff;">
      Subscribe to Newsletter
    </a>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.video-card').forEach(card => {
    const btn = card.querySelector('.video-thumb');
    const id = card.dataset.id;
    btn.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
      iframe.allow = 'autoplay; encrypted-media';
      iframe.allowFullscreen = true;
      iframe.className = 'w-full h-44';
      btn.replaceWith(iframe);
    });
  });
</script>

<style>
  @keyframes hero-fade {
    0%,  20%  { opacity: 1; }
    25%, 100% { opacity: 0; }
  }
  .carousel-slide {
    animation: hero-fade 24s linear infinite;
    opacity: 0;
  }
</style>
