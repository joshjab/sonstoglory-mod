---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const newsletters = (await getCollection('newsletters'))
  .filter(n => n.data.type === 'newsletter' && n.data.number)
  .sort((a, b) => (b.data.number ?? 0) - (a.data.number ?? 0))
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/(\/?)$/, '/');

// CSS-only carousel: 4 photos cycle behind the hero (24s total, 6s each)
const carouselImages = [
  'images/newsletters/pictures/King_Jesus_in_the_Clouds_as_Bridegroom.JPG',
  'images/newsletters/pictures/3crosses.jpg',
  'images/newsletters/pictures/dove_with_an_olive_branch.jpg',
  'images/newsletters/pictures/GloryRide1.jpg',
];
// Delays: slide N is offset N×6s back in a 24s cycle
const delays = ['0s', '-18s', '-12s', '-6s'];

// Pull the first image src out of a newsletter's raw Markdown body
function extractCardImage(body) {
  const m = body.match(/<img[^>]+src="([^"]+)"/);
  if (!m) return null;
  const src = m[1];
  // Prefix root-relative paths with base
  return src.startsWith('/') ? `${base}${src.slice(1)}` : src;
}
---

<BaseLayout title="Home" description="Theological writings, newsletters, and resources by Paul Jablonowski — freely given for the Everlasting Kingdom of Jesus.">

  <!-- Hero with CSS carousel -->
  <section class="relative text-white overflow-hidden" style="min-height: 420px;">

    <!-- Carousel slides (CSS animation, no JS) -->
    {carouselImages.map((img, i) => (
      <div
        class="carousel-slide absolute inset-0 bg-no-repeat bg-center"
        style={`background-image: url('${base}${img}'); background-size: 70%; animation-delay: ${delays[i]};`}
      />
    ))}

    <!-- Dark overlay — cosmic navy from book cover palette -->
    <div class="absolute inset-0 bg-cosmic" style="opacity: 0.82;" />

    <!-- Content -->
    <div class="relative z-10 max-w-3xl mx-auto text-center py-20 px-4">
      <p class="text-sm font-semibold uppercase tracking-widest text-blue-200 mb-3">
        Freely Given for the Kingdom of Jesus Christ
      </p>
      <h1 class="font-heading text-5xl md:text-6xl font-bold text-white mb-6 leading-tight">
        Sons To Glory
      </h1>
      <p class="text-lg text-blue-100 mb-10 leading-relaxed max-w-xl mx-auto">
        Theological writings on sonship, the Biblical feasts, prophecy,
        and the Everlasting Kingdom — by Paul Jablonowski.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}book/`} class="bg-accent text-white px-7 py-3 rounded font-semibold no-underline hover:opacity-90 transition-opacity">
          Read the Book
        </a>
        <a href={`${base}newsletters/`} class="border-2 border-white text-white px-7 py-3 rounded font-semibold no-underline hover:bg-white hover:text-primary transition-colors">
          Browse Newsletters
        </a>
      </div>
    </div>

  </section>

  <!-- Latest Newsletters -->
  <section class="max-w-5xl mx-auto px-4 py-14">
    <h2 class="font-heading text-3xl text-primary mb-8">Latest Newsletters</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {newsletters.map(n => {
        const cardImage = extractCardImage(n.body);
        const displayTitle = n.data.title.replace(/^Newsletter #\d+\s*[-—]?\s*/i, '');
        const formattedDate = n.data.date
          ? new Date(n.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })
          : null;
        return (
          <a
            href={`${base}newsletters/${n.slug}/`}
            class="flex flex-col bg-white rounded-lg shadow-sm border border-gray-100 no-underline hover:shadow-md transition-shadow overflow-hidden"
          >
            {/* Card image */}
            {cardImage ? (
              <div class="h-40 overflow-hidden bg-gray-100">
                <img
                  src={cardImage}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="h-40 bg-primary flex items-center justify-center">
                <span class="font-heading text-4xl font-bold text-white opacity-30">
                  #{n.data.number}
                </span>
              </div>
            )}
            {/* Card text */}
            <div class="p-5 flex flex-col flex-1">
              <span class="text-xs font-semibold text-accent uppercase tracking-wide mb-1">
                Issue #{n.data.number}
              </span>
              <h3 class="font-heading text-base text-primary leading-snug font-semibold mb-2 flex-1">
                {displayTitle}
              </h3>
              {formattedDate && (
                <p class="text-xs text-gray-400 mt-auto">{formattedDate}</p>
              )}
            </div>
          </a>
        );
      })}
    </div>
    <div class="mt-8 text-center">
      <a href={`${base}newsletters/`} class="text-primary font-semibold hover:text-accent">
        View all 41 newsletters →
      </a>
    </div>
  </section>

  <!-- Free Book CTA -->
  <section class="bg-cosmic py-14 px-4">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-10">
      <!-- Book cover -->
      <div class="flex gap-3 shrink-0">
        <img
          src={`${base}images/images/sonstoglorycover.jpg`}
          alt="Sons To Glory book cover"
          class="h-52 w-auto shadow-lg rounded"
        />
        <img
          src={`${base}images/images/sonstoglorybackcover.jpg`}
          alt="Sons To Glory back cover"
          class="h-52 w-auto shadow-lg rounded hidden sm:block"
        />
      </div>
      <!-- Text -->
      <div>
        <h2 class="font-heading text-3xl text-white mb-3">Sons To Glory — Free Book</h2>
        <p class="text-blue-200 mb-6 text-lg leading-relaxed">
          A multi-chapter exploration of spiritual sonship, the Biblical feasts, and the
          Everlasting Kingdom. Read online or download the PDF — freely given.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`${base}book/`} class="bg-accent text-white px-6 py-3 rounded font-semibold no-underline hover:opacity-90 text-center">
            Read Online
          </a>
          <a href={`${base}pdfs/SonsToGloryBook.pdf`} target="_blank" class="border border-accent text-accent px-6 py-3 rounded font-semibold no-underline hover:bg-accent hover:text-white transition-colors text-center">
            Download PDF
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Subscribe CTA -->
  <section class="bg-nebula py-14 px-4 text-center">
    <h2 class="font-heading text-2xl text-white mb-3">Stay Connected</h2>
    <p class="text-purple-200 mb-6">
      Subscribe to receive new writings and updates from Paul Jablonowski.
    </p>
    <a href={`${base}subscribe/`} class="bg-accent text-white px-6 py-3 rounded font-semibold no-underline hover:opacity-90 inline-block">
      Subscribe to Newsletter
    </a>
  </section>

</BaseLayout>

<style>
  @keyframes hero-fade {
    0%,  20%  { opacity: 1; }
    25%, 100% { opacity: 0; }
  }
  .carousel-slide {
    animation: hero-fade 24s linear infinite;
    opacity: 0;
  }
</style>
