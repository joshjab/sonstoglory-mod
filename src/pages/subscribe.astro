---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Subscribe" description="Subscribe to receive new writings and updates from Paul Jablonowski.">
  <div class="max-w-xl mx-auto px-4 py-16 text-center">
    <h1 class="font-heading text-4xl text-primary mb-4">Subscribe</h1>
    <p class="text-gray-600 text-lg mb-8">
      Enter your email below to receive new newsletters and updates from Paul Jablonowski —
      freely given for the Kingdom of Jesus Christ.
    </p>
    <!-- Newsletter signup embed goes here (ConvertKit / Buttondown — Milestone 2.6) -->
    <div class="border-2 border-dashed border-gray-200 rounded-lg p-10 text-gray-400 text-sm">
      Newsletter signup form coming soon.
    </div>
  </div>
</BaseLayout>
